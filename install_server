#!/bin/sh
if [ "$(id -u)" -ne 0 ]; then
  echo "Please run with sudo"
  exit 1
fi

APP_DIR="/opt/virtualhere"
CONF_DIR="/etc/virtualhere"
UNIT="/etc/systemd/system/virtualhere.service"

if [ -n "$1" ]; then
  FILENAME="$1"
else
  ARCH=$(uname -m)
  if [ -z "${ARCH##*arm*}" ]; then
    FILENAME="vhusbdarm"
  elif [ "$ARCH" = "mips" ]; then
    FILENAME="vhusbdmips"
  elif [ "$ARCH" = "mipsel" ]; then
    FILENAME="vhusbdmipsel"
  elif [ -z "${ARCH##*x86_64*}" ]; then
    FILENAME="vhusbdx86_64"
  elif [ -z "${ARCH##*aarch64*}" ]; then
    FILENAME="vhusbdarm64"
  else
    FILENAME="vhusbdi386"
  fi
fi

URL="https://www.virtualhere.com/sites/default/files/usbserver/$FILENAME"
if command -v wget >/dev/null 2>&1; then
  wget "$URL"
elif command -v curl >/dev/null 2>&1; then
  curl -fL -o "$FILENAME" "$URL"
else
  echo "Error: wget or curl is required"
  exit 1
fi

chmod +x "$FILENAME"
mkdir -p "$APP_DIR" "$CONF_DIR"
mv "$FILENAME" "$APP_DIR"

if [ -d "/etc/systemd/system" ]; then
  cat << EOF > "$UNIT"
[Unit]
Description=VirtualHere Server
After=network.target

[Service]
Type=forking
ExecStart=$APP_DIR/$FILENAME -b -c $CONF_DIR/config.ini

[Install]
WantedBy=multi-user.target
EOF
  systemctl daemon-reload
  systemctl enable virtualhere.service
  systemctl start virtualhere.service
else
  echo "Error, only systemd is supported"
fi
